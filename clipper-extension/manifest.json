{
  "manifest_version": 3,
  "name": "Personal Wiki Clipper",
  "version": "1.3",
  "description": "Clip web pages to your self-hosted Personal Wiki",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
